APP_NAME=MoviePilot Subtitle Agent
APP_VERSION=0.1.5
HOST=0.0.0.0
PORT=8178
DEBUG=false

DEFAULT_LANGUAGES=zh-cn,zh-tw
DEFAULT_PROVIDERS=assrt,subhd
ENABLE_SUBLIMINAL_FALLBACK=true
SUBLIMINAL_FALLBACK_PROVIDERS=podnapisi,tvsubtitles,opensubtitlescom,opensubtitles
MAX_RESULTS=30
TOKEN_TTL_SECONDS=1800
REQUEST_TIMEOUT_SECONDS=20
SUBTITLE_OUTPUT_DIR=data/subtitles
USER_AGENT=MoviePilotSubtitleAgent/0.2

# Optional provider credentials
ADDIC7ED_USERNAME=
ADDIC7ED_PASSWORD=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
OPENSUBTITLESCOM_USERNAME=
OPENSUBTITLESCOM_PASSWORD=
OPENSUBTITLESCOM_API_KEY=
