APP_NAME=MoviePilot Subtitle Agent
APP_VERSION=0.2.23
HOST=0.0.0.0
PORT=8178
DEBUG=false

DEFAULT_LANGUAGES=zh-cn,zh-tw
DEFAULT_PROVIDERS=assrt,subhd,subhdtw
PROVIDER_STAGE_ORDER=assrt,subhd,subhdtw|podnapisi,tvsubtitles|opensubtitlescom,opensubtitles
ENABLE_SUBLIMINAL_FALLBACK=true
SUBLIMINAL_FALLBACK_PROVIDERS=podnapisi,tvsubtitles,opensubtitlescom,opensubtitles
MAX_RESULTS=30
MIN_SCORE=0
ENABLE_PARALLEL_SEARCH=true
SEARCH_WORKERS=6
ENABLE_ADAPTIVE_PROVIDER_PRIORITY=true
