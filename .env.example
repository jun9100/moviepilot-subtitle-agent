APP_NAME=MoviePilot Subtitle Agent
APP_VERSION=0.2.10
HOST=0.0.0.0
PORT=8178
DEBUG=false

DEFAULT_LANGUAGES=zh-cn,zh-tw
DEFAULT_PROVIDERS=assrt,subhd,subhdtw
PROVIDER_STAGE_ORDER=assrt,subhd,subhdtw|podnapisi,tvsubtitles|opensubtitlescom,opensubtitles
ENABLE_SUBLIMINAL_FALLBACK=true
SUBLIMINAL_FALLBACK_PROVIDERS=podnapisi,tvsubtitles,opensubtitlescom,opensubtitles
MAX_RESULTS=30
MIN_SCORE=0
ENABLE_PARALLEL_SEARCH=true
SEARCH_WORKERS=6
TOKEN_TTL_SECONDS=1800
REQUEST_TIMEOUT_SECONDS=20
SUBTITLE_OUTPUT_DIR=data/subtitles
USER_AGENT=MoviePilotSubtitleAgent/0.2
ALLOW_SEASON_PACK_FOR_EPISODE=true
STRICT_MEDIA_TYPE_FILTER=true
ENABLE_CONTENT_LANGUAGE_VALIDATION=true
CHINESE_CONFIDENCE_THRESHOLD=0.25
CHINESE_CONFIDENCE_MIN_CHARS=4
SUBHD_CAPTCHA_COOLDOWN_SECONDS=1800
SUBHD_COOKIE_STRING=
SUBHD_COOKIE_FILE=
SUBHD_COOKIECLOUD_URL=
SUBHD_COOKIECLOUD_KEY=
SUBHD_COOKIECLOUD_PASSWORD=
SUBHD_COOKIECLOUD_SYNC_INTERVAL_SECONDS=1800

# Optional provider credentials
ADDIC7ED_USERNAME=
ADDIC7ED_PASSWORD=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=
OPENSUBTITLESCOM_USERNAME=
OPENSUBTITLESCOM_PASSWORD=
OPENSUBTITLESCOM_API_KEY=
