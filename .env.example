PROVIDER_PRIORITY_PERSIST_INTERVAL_SECONDS=30
TOKEN_TTL_SECONDS=1800
REQUEST_TIMEOUT_SECONDS=20
SUBTITLE_OUTPUT_DIR=data/subtitles
USER_AGENT=MoviePilotSubtitleAgent/0.2
ALLOW_SEASON_PACK_FOR_EPISODE=true
STRICT_MEDIA_TYPE_FILTER=true
ENABLE_CONTENT_LANGUAGE_VALIDATION=true
CHINESE_CONFIDENCE_THRESHOLD=0.25
CHINESE_CONFIDENCE_MIN_CHARS=4
SUBHD_CAPTCHA_COOLDOWN_SECONDS=1800
SUBHD_COOKIE_STRING=
SUBHD_COOKIE_FILE=
ENABLE_CAPTCHA_OCR=false
CAPTCHA_OCR_ENDPOINT=
CAPTCHA_OCR_TIMEOUT_SECONDS=8
CAPTCHA_OCR_AUTO_SUBMIT=false
CAPTCHA_OCR_AUTO_MAX_ATTEMPTS=5
CAPTCHA_OCR_MIN_CONFIDENCE=0.0
COOKIECLOUD_URL=
COOKIECLOUD_KEY=
COOKIECLOUD_PASSWORD=
COOKIECLOUD_SYNC_INTERVAL_SECONDS=1800
